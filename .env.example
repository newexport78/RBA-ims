# Copy to .env and set for production
DEBUG=False
SECRET_KEY=your-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
# Optional: explicit CSRF origins (https://...). If omitted, derived from ALLOWED_HOSTS.
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DATABASE_URL=postgres://user:pass@host:5432/dbname

# OTP email — pick one (production). If USE_SES=true, SES is used; else SendGrid if SENDGRID_API_KEY is set.
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
#
# A) SendGrid (use while SES sandbox blocks recipients): MUST set USE_SES=false and a real key:
# USE_SES=false
# SENDGRID_API_KEY=SG.xxx
# Verify DEFAULT_FROM_EMAIL (or domain) in SendGrid → Sender Authentication.
#
# B) Amazon SES (after production access or for verified recipients only):
# USE_SES=true
# AWS_SES_REGION_NAME=ap-south-1
#
# Local: DEBUG=true → OTP prints to console.

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional: ALB health checks send Host as private IP; /health/ needs a host in ALLOWED_HOSTS
# HEALTH_CHECK_HOST=rbac-ims.com

# Optional
OTP_EXPIRY_MINUTES=10
SESSION_COOKIE_AGE=3600
SESSION_SAVE_EVERY_REQUEST=True
